# OpusGod Agent Configuration
# Copy to .env and fill in values: cp .env.example .env

# === REQUIRED ===
# Agent Ethereum private key (0x-prefixed, 64 hex chars)
OPUS_PRIVATE_KEY=0x<your-64-char-hex-key>

# === Bankr LLM Gateway ===
OPUS_BANKR_API_KEY=
OPUS_BANKR_ENDPOINT=https://llm.bankr.bot/v1/chat/completions
OPUS_BANKR_MODEL=gpt-4o

# === Telegram Alerts ===
OPUS_TELEGRAM_BOT_TOKEN=
OPUS_TELEGRAM_CHAT_ID=

# === Zyfai Yield SDK ===
OPUS_ZYFAI_API_KEY=
OPUS_ZYFAI_SAFE_ADDRESS=

# === Ampersend x402 Payments ===
OPUS_AMPERSEND_API_KEY=

# === Chain RPCs ===
OPUS_GNOSIS_RPC=https://rpc.gnosischain.com
OPUS_BASE_RPC=https://mainnet.base.org

# === Mech Server ===
OPUS_MECH_SERVER_PORT=8080
OPUS_MECH_TARGET_ADDRESS=0x77af31De935740567Cf4fF1986D04B2c964A786a
OPUS_MECH_CONTRACT_ADDRESS=
OPUS_MECH_API_KEY=

# === Slice Commerce (Base) ===
OPUS_SLICE_CONTRACT_ADDRESS=

# === Lido Monitoring ===
OPUS_LIDO_API_URL=https://eth-api.lido.fi

# === Pearl Dashboard ===
OPUS_PEARL_PORT=8716

# === Scheduling ===
OPUS_POLL_INTERVAL_SECONDS=30
OPUS_VAULT_CHECK_INTERVAL_SECONDS=300
